#!/usr/bin/env bash
# Strict helper for the small Org dialect used by the org-plan skill.
set -Eeuo pipefail

usage() { printf 'usage: org-plan {validate|next|summary|l2|set|prepare-executor} [args]\n' >&2; exit 2; }
die() { printf '%s: %s\n' "$plan" "$*" >&2; return 1; }
declare -a ids states levels lines titles parents starts ends
declare -A seen field
count=0

parse() {
  plan=$1; [ -r "$plan" ] || die 'unreadable plan'
  ids=() states=() levels=() lines=() titles=() parents=() starts=() ends=(); seen=() field=(); count=0
  local line n=0 current=-1 drawer=0 id='' last_l1=-1
  local -a metadata=(TITLE SUBTITLE DATE KEYWORDS)
  declare -A meta=()
  while IFS= read -r line || [ -n "$line" ]; do
    n=$((n + 1))
    if [[ $line =~ ^#\+([A-Z]+): ]]; then
      local key=${BASH_REMATCH[1]}; case " ${metadata[*]} " in *" $key "*) meta[$key]=$(( ${meta[$key]:-0} + 1 ));; esac
    fi
    if [[ $line =~ ^(\*+)[[:space:]]+([^[:space:]]+)[[:space:]]+(\[#([ABC])\])[[:space:]]+(.+)$ ]]; then
      local stars state title level
      stars=${BASH_REMATCH[1]}; state=${BASH_REMATCH[2]}; title=${BASH_REMATCH[5]}; level=${#stars}
      (( level <= 2 )) || die "line $n: unsupported heading depth"
      [[ $state =~ ^(TODO|WIP|DONE)$ ]] || die "line $n: invalid state"
      (( current >= 0 )) && ends[$current]=$((n - 1))
      current=$count; count=$((count + 1)); levels[$current]=$level; states[$current]=$state; lines[$current]=$n; titles[$current]=$title; starts[$current]=$n; ends[$current]=0; id=''; drawer=0
      if (( level == 1 )); then last_l1=$current; parents[$current]=-1; else (( last_l1 >= 0 )) || die "line $n: L2 without L1"; parents[$current]=$last_l1; fi
      continue
    elif [[ $line =~ ^\*+ ]]; then die "line $n: malformed executable heading"; fi
    (( current >= 0 )) || continue
    if [[ $line == ':PROPERTIES:' ]]; then (( drawer == 0 )) || die "line $n: malformed property drawer"; drawer=1; continue; fi
    if (( drawer == 1 )); then
      if [[ $line == ':END:' ]]; then drawer=2; continue; fi
      if [[ $line =~ ^:ID:[[:space:]]*(.+)$ ]]; then id=${BASH_REMATCH[1]}; continue; fi
      die "line $n: malformed property drawer"
    fi
    if [[ $line =~ ^-[[:space:]]+([^:]+)[[:space:]]+::[[:space:]]*(.*)$ ]]; then field["$current:${BASH_REMATCH[1]}"]=1; fi
  done < "$plan"
  (( current >= 0 )) && ends[$current]=$n
  for key in "${metadata[@]}"; do [[ ${meta[$key]:-0} == 1 ]] || die "metadata $key must appear exactly once"; done
  (( count > 0 )) || die 'no executable headings'
  local i x
  for ((i=0; i<count; i++)); do
    [[ ${ends[$i]} != 0 ]] || ends[$i]=$n
    # ID was intentionally captured per heading into a line-indexed field.
    id=$(sed -n "$((starts[$i]+1)),$((ends[$i]))p" "$plan" | awk '/^:ID:[[:space:]]*/ {sub(/^:ID:[[:space:]]*/, ""); print; exit}')
    [[ $id =~ ^[a-z0-9]+(-[a-z0-9]+)*$ ]] || die "line ${lines[$i]}: missing or invalid ID"
    [[ -z ${seen[$id]:-} ]] || die "line ${lines[$i]}: duplicate ID $id"; seen[$id]=$i; ids[$i]=$id
    if (( levels[$i] == 1 )); then
      for x in Effort Goal Notes; do [[ ${field[$i:$x]:-} == 1 ]] || die "line ${lines[$i]} ($id): missing field $x"; done
    else
      for x in Why Change Tests; do [[ ${field[$i:$x]:-} == 1 ]] || die "line ${lines[$i]} ($id): missing field $x"; done
      [[ ${field[$i:Done when]:-} == 1 ]] || die "line ${lines[$i]} ($id): missing field Done when"
    fi
  done
  local wip_l1=0 wip_l2=0 parent
  for ((i=0; i<count; i++)); do
    if (( levels[$i] == 1 )); then [[ ${states[$i]} != WIP ]] || wip_l1=$((wip_l1+1)); continue; fi
    parent=${parents[$i]}
    [[ ${states[$parent]} != DONE || ${states[$i]} == DONE ]] || die "line ${lines[$i]} (${ids[$i]}): unfinished child of DONE parent"
    [[ ${states[$parent]} != TODO || ${states[$i]} == TODO ]] || die "line ${lines[$i]} (${ids[$i]}): active child outside WIP L1"
    [[ ${states[$i]} != WIP ]] || wip_l2=$((wip_l2+1))
  done
  (( wip_l1 <= 1 )) || die 'multiple WIP L1s'
  (( wip_l2 <= 1 )) || die 'multiple WIP L2s'
}
find_id() { local i; for ((i=0;i<count;i++)); do [[ ${ids[$i]} == "$1" ]] && { printf '%s' "$i"; return; }; done; return 1; }
print_item() { local i=$1; printf '%s %s [#%s] %s\n' "${levels[$i]#1}" "${ids[$i]}" "${states[$i]}" "${titles[$i]}"; }
active_l1() { local i; for ((i=0;i<count;i++)); do (( levels[$i] == 1 )) && [[ ${states[$i]} == WIP ]] && { printf '%s' "$i"; return; }; done; for ((i=0;i<count;i++)); do (( levels[$i] == 1 )) && [[ ${states[$i]} == TODO ]] && { printf '%s' "$i"; return; }; done; return 1; }

valid_model() { [[ $1 =~ ^[A-Za-z0-9][A-Za-z0-9._-]*$ ]]; }
valid_profile_name() { [[ $1 =~ ^[a-z0-9][a-z0-9-]*$ ]]; }

written_profile=
write_profile() {
  local profile_name=$1 description=$2 instructions=$3 model=$4 agents_dir=$5 sandbox_mode=${6:-}
  local destination="$agents_dir/$profile_name.toml" temporary mode
  mkdir -p -- "$agents_dir"
  temporary=$(mktemp "$agents_dir/.$profile_name.XXXXXX")
  trap 'rm -f -- "${temporary:-}"' EXIT HUP INT TERM
  mode=$(stat -c '%a' "$destination" 2>/dev/null || stat -f '%Lp' "$destination" 2>/dev/null || printf '600')
  {
    printf 'name = "%s"\n' "$profile_name"
    printf 'description = "%s"\n' "$description"
    printf 'developer_instructions = "%s"\n' "$instructions"
    printf 'model = "%s"\n' "$model"
    [[ -z $sandbox_mode ]] || printf 'sandbox_mode = "%s"\n' "$sandbox_mode"
  } > "$temporary"
  chmod "$mode" "$temporary"
  mv -f -- "$temporary" "$destination"
  trap - EXIT HUP INT TERM
  written_profile=$destination
}

prepare_executor() {
  local model='gpt-5.6-terra' profile_name='org-plan-executor' agents_dir="${HOME:?HOME is required}/.codex/agents"
  while (( $# )); do
    case $1 in
      --model) (( $# >= 2 )) || usage; model=$2; shift 2 ;;
      --agents-dir) (( $# >= 2 )) || usage; agents_dir=$2; shift 2 ;;
      --profile-name) (( $# >= 2 )) || usage; profile_name=$2; shift 2 ;;
      *) usage ;;
    esac
  done
  valid_model "$model" || { printf 'invalid model: %s\n' "$model" >&2; return 2; }
  valid_profile_name "$profile_name" || { printf 'invalid profile name: %s\n' "$profile_name" >&2; return 2; }
  write_profile "$profile_name" 'Executes an org-plan implementation.' \
    'Follow the assigned Org plan strictly. Use the bundled org-plan helper for state changes, run required tests, and return concise evidence to the planner.' \
    "$model" "$agents_dir"
  printf 'executor=%s model=%s profile=%s\n' "$profile_name" "$model" "$written_profile"
}

cmd=${1:-}; shift || true
case $cmd in
  prepare-executor) prepare_executor "$@" ;;
  validate) [ $# = 1 ] || usage; parse "$1" ;;
  next)
    [ $# = 2 ] || usage; parse "$1"; case $2 in
      l1) i=$(active_l1) || exit 1; print_item "$i" ;;
      l2) p=$(active_l1) || exit 1; for ((i=0;i<count;i++)); do (( levels[$i] == 2 && parents[$i] == p )) && [[ ${states[$i]} == WIP ]] && { print_item "$i"; exit; }; done; for ((i=0;i<count;i++)); do (( levels[$i] == 2 && parents[$i] == p )) && [[ ${states[$i]} == TODO ]] && { print_item "$i"; exit; }; done; exit 1 ;;
      *) usage;; esac ;;
  summary)
    [ $# = 1 ] || usage; parse "$1"
    for s in TODO WIP DONE; do n=0; for ((i=0;i<count;i++)); do (( levels[i] == 1 )) && [[ ${states[i]} == "$s" ]] && n=$((n+1)); done; printf 'L1 %s=%s\n' "$s" "$n"; done
    for s in TODO WIP DONE; do n=0; for ((i=0;i<count;i++)); do (( levels[i] == 2 )) && [[ ${states[i]} == "$s" ]] && n=$((n+1)); done; printf 'L2 %s=%s\n' "$s" "$n"; done
    i=$(active_l1) && { printf 'current '; print_item "$i"; } ;;
  l2)
    [ $# = 2 ] || usage; parse "$1"; grep -E -- "$2" /dev/null >/dev/null 2>&1 || { [ $? = 1 ] || die 'invalid regular expression'; }
    matched=0; for ((i=0;i<count;i++)); do (( levels[i] == 2 )) || continue; block=$(sed -n "${starts[$i]},${ends[$i]}p" "$plan"); if printf '%s\n' "$block" | grep -E -q -- "$2"; then printf '%s\n' "$block"; matched=1; fi; done; (( matched )) || die 'no matching L2 blocks' ;;
  set)
    if [ $# -lt 3 ] || [ $# -gt 4 ]; then usage; fi; original=$1; parse "$original"; target=$(find_id "$2") || die "unknown ID $2"; new=$3; force=${4:-}; [[ $new =~ ^(TODO|WIP|DONE)$ ]] || usage
    old=${states[$target]}; [[ -z $force || $force == --force ]] || usage
    if [[ -z $force ]]; then [[ ($old == TODO && $new == WIP) || ($old == WIP && $new == DONE) ]] || die "invalid transition $old -> $new"; fi
    if [[ -n $force ]]; then printf 'force: overriding %s -> %s\n' "$old" "$new" >&2; fi
    tmp=$(mktemp "${original}.tmp.XXXXXX"); trap 'rm -f "$tmp"' EXIT HUP INT TERM; mode=$(stat -c '%a' "$original" 2>/dev/null || stat -f '%Lp' "$original")
    awk -v line="${lines[$target]}" -v state="$new" 'NR==line { sub(/TODO|WIP|DONE/, state) } {print}' "$original" > "$tmp"
    plan=$original
    lines[$target]=${lines[$target]}
    chmod "$mode" "$tmp"; parse "$tmp"; mv "$tmp" "$original"; trap - EXIT HUP INT TERM ;;
  --help|-h|'') usage ;;
  *) usage ;;
esac

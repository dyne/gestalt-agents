#!/usr/bin/env bash
# Strict helper for the small Org dialect used by the org-plan skill.
set -Eeuo pipefail

usage() { printf 'usage: org-plan {validate|next|summary|describe|review|l2|set|prepare-executor|prepare-supervision} [args]\n' >&2; exit 2; }
die() { printf '%s: %s\n' "$plan" "$*" >&2; return 1; }
declare -a ids states levels lines titles parents starts ends review_status review_status_count review_lines
declare -A seen field field_value
count=0

parse() {
  plan=$1; [ -r "$plan" ] || die 'unreadable plan'
  ids=() states=() levels=() lines=() titles=() parents=() starts=() ends=(); review_status=() review_status_count=() review_lines=(); seen=() field=() field_value=(); count=0
  local line n=0 current=-1 drawer=0 id='' last_l1=-1
  local -a metadata=(TITLE SUBTITLE DATE KEYWORDS)
  declare -A meta=()
  while IFS= read -r line || [ -n "$line" ]; do
    n=$((n + 1))
    if [[ $line =~ ^#\+([A-Z]+): ]]; then
      local key=${BASH_REMATCH[1]}; case " ${metadata[*]} " in *" $key "*) meta[$key]=$(( ${meta[$key]:-0} + 1 ));; esac
    fi
    if [[ $line =~ ^(\*+)[[:space:]]+([^[:space:]]+)[[:space:]]+(\[#([ABC])\])[[:space:]]+(.+)$ ]]; then
      local stars state title level
      stars=${BASH_REMATCH[1]}; state=${BASH_REMATCH[2]}; title=${BASH_REMATCH[5]}; level=${#stars}
      (( level <= 2 )) || die "line $n: unsupported heading depth"
      [[ $state =~ ^(TODO|WIP|DONE)$ ]] || die "line $n: invalid state"
      (( current >= 0 )) && ends[$current]=$((n - 1))
      current=$count; count=$((count + 1)); levels[$current]=$level; states[$current]=$state; lines[$current]=$n; titles[$current]=$title; starts[$current]=$n; ends[$current]=0; id=''; drawer=0
      if (( level == 1 )); then last_l1=$current; parents[$current]=-1; else (( last_l1 >= 0 )) || die "line $n: L2 without L1"; parents[$current]=$last_l1; fi
      continue
    elif [[ $line =~ ^\*+ ]]; then die "line $n: malformed executable heading"; fi
    (( current >= 0 )) || continue
    if [[ $line == ':PROPERTIES:' ]]; then (( drawer == 0 )) || die "line $n: malformed property drawer"; drawer=1; continue; fi
    if (( drawer == 1 )); then
      if [[ $line == ':END:' ]]; then drawer=2; continue; fi
      if [[ $line =~ ^:ID:[[:space:]]*(.+)$ ]]; then id=${BASH_REMATCH[1]}; continue; fi
      if [[ $line =~ ^:REVIEW_STATUS:[[:space:]]*(.*)$ ]]; then
        (( levels[$current] == 1 )) || die "line $n: REVIEW_STATUS is only valid on L1 headings"
        review_status_count[$current]=$(( ${review_status_count[$current]:-0} + 1 ))
        (( review_status_count[$current] == 1 )) || die "line $n: duplicate REVIEW_STATUS"
        review_status[$current]=${BASH_REMATCH[1]}
        [[ ${review_status[$current]} =~ ^(UNREVIEWED|REVIEWED)$ ]] || die "line $n: invalid REVIEW_STATUS"
        review_lines[$current]=$n
        continue
      fi
      die "line $n: malformed property drawer"
    fi
    if [[ $line =~ ^-[[:space:]]+([^:]+)[[:space:]]+::[[:space:]]*(.*)$ ]]; then
      field["$current:${BASH_REMATCH[1]}"]=1
      field_value["$current:${BASH_REMATCH[1]}"]=${BASH_REMATCH[2]}
    fi
  done < "$plan"
  (( current >= 0 )) && ends[$current]=$n
  for key in "${metadata[@]}"; do [[ ${meta[$key]:-0} == 1 ]] || die "metadata $key must appear exactly once"; done
  (( count > 0 )) || die 'no executable headings'
  local i x
  for ((i=0; i<count; i++)); do
    [[ ${ends[$i]} != 0 ]] || ends[$i]=$n
    # ID was intentionally captured per heading into a line-indexed field.
    id=$(sed -n "$((starts[$i]+1)),$((ends[$i]))p" "$plan" | awk '/^:ID:[[:space:]]*/ {sub(/^:ID:[[:space:]]*/, ""); print; exit}')
    [[ $id =~ ^[a-z0-9]+(-[a-z0-9]+)*$ ]] || die "line ${lines[$i]}: missing or invalid ID"
    [[ -z ${seen[$id]:-} ]] || die "line ${lines[$i]}: duplicate ID $id"; seen[$id]=$i; ids[$i]=$id
    if (( levels[$i] == 1 )); then
      [[ ${review_status_count[$i]:-0} == 1 ]] || die "line ${lines[$i]} ($id): missing REVIEW_STATUS"
      for x in Effort Goal Notes; do [[ ${field[$i:$x]:-} == 1 ]] || die "line ${lines[$i]} ($id): missing field $x"; done
    else
      for x in Why Change Tests; do [[ ${field[$i:$x]:-} == 1 ]] || die "line ${lines[$i]} ($id): missing field $x"; done
      [[ ${field[$i:Done when]:-} == 1 ]] || die "line ${lines[$i]} ($id): missing field Done when"
    fi
  done
  local wip_l1=0 wip_l2=0 parent
  for ((i=0; i<count; i++)); do
    if (( levels[$i] == 1 )); then [[ ${states[$i]} != WIP ]] || wip_l1=$((wip_l1+1)); continue; fi
    parent=${parents[$i]}
    [[ ${states[$parent]} != DONE || ${states[$i]} == DONE ]] || die "line ${lines[$i]} (${ids[$i]}): unfinished child of DONE parent"
    [[ ${states[$parent]} != TODO || ${states[$i]} == TODO ]] || die "line ${lines[$i]} (${ids[$i]}): active child outside WIP L1"
    [[ ${states[$i]} != WIP ]] || wip_l2=$((wip_l2+1))
  done
  (( wip_l1 <= 1 )) || die 'multiple WIP L1s'
  (( wip_l2 <= 1 )) || die 'multiple WIP L2s'
}
find_id() { local i; for ((i=0;i<count;i++)); do [[ ${ids[$i]} == "$1" ]] && { printf '%s' "$i"; return; }; done; return 1; }
print_item() { local i=$1; printf '%s %s [#%s] %s\n' "${levels[$i]#1}" "${ids[$i]}" "${states[$i]}" "${titles[$i]}"; }
active_l1() { local i; for ((i=0;i<count;i++)); do (( levels[$i] == 1 )) && [[ ${states[$i]} == WIP ]] && { printf '%s' "$i"; return; }; done; for ((i=0;i<count;i++)); do (( levels[$i] == 1 )) && [[ ${states[$i]} == TODO ]] && { printf '%s' "$i"; return; }; done; return 1; }
write_plan_candidate() {
  local original=$1 candidate=$2 mode
  mode=$(stat -c '%a' "$original" 2>/dev/null || stat -f '%Lp' "$original")
  chmod "$mode" "$candidate"
  parse "$candidate"
  mv "$candidate" "$original"
  trap - EXIT HUP INT TERM
}

valid_model() { [[ $1 =~ ^[A-Za-z0-9][A-Za-z0-9._-]*$ ]]; }
valid_profile_name() { [[ $1 =~ ^[a-z0-9][a-z0-9-]*$ ]]; }

written_profile=
profile_stage_dir=
profile_stage_owned=0
profile_installing=0
declare -a staged_profiles=() profile_destinations=() profile_backups=() profile_had_destination=()
cleanup_profile_stage() {
  [[ -n $profile_stage_dir ]] || return 0
  if (( profile_stage_owned )); then rm -rf -- "$profile_stage_dir"; else rmdir -- "$profile_stage_dir" 2>/dev/null || true; fi
  profile_stage_owned=0
}
rollback_profiles() {
  (( profile_installing )) || return 0
  local index
  for ((index=0; index<${#profile_destinations[@]}; index++)); do
    if [[ ${profile_had_destination[$index]} == 1 ]]; then
      cp -p -- "${profile_backups[$index]}" "${profile_destinations[$index]}"
    else
      rm -f -- "${profile_destinations[$index]}"
    fi
  done
  profile_installing=0
}
profile_exit_cleanup() { local status=$?; rollback_profiles; cleanup_profile_stage; return "$status"; }
profile_signal_cleanup() {
  local signal=$1 status
  case $signal in HUP) status=129 ;; INT) status=130 ;; TERM) status=143 ;; esac
  trap - HUP INT TERM
  rollback_profiles
  cleanup_profile_stage
  trap - EXIT
  exit "$status"
}
begin_profile_transaction() {
  local agents_dir=$1 suffix="${RANDOM}${RANDOM}"
  mkdir -p -- "$agents_dir"
  profile_stage_dir="$agents_dir/.org-plan-stage.$$.${suffix}"
  profile_stage_owned=0
  staged_profiles=() profile_destinations=() profile_backups=() profile_had_destination=()
  profile_installing=0
  trap profile_exit_cleanup EXIT
  trap 'profile_signal_cleanup HUP' HUP
  trap 'profile_signal_cleanup INT' INT
  trap 'profile_signal_cleanup TERM' TERM
  if mkdir -m 700 -- "$profile_stage_dir"; then
    profile_stage_owned=1
  else
    profile_stage_owned=0
    profile_stage_dir=
    return 1
  fi
}
finish_profile_transaction() {
  cleanup_profile_stage
  trap - EXIT HUP INT TERM
  profile_stage_dir=
  staged_profiles=() profile_destinations=() profile_backups=() profile_had_destination=()
}
stage_profile() {
  local profile_name=$1 description=$2 instructions=$3 model=$4 agents_dir=$5 sandbox_mode=${6:-}
  local destination="$agents_dir/$profile_name.toml" temporary="$profile_stage_dir/$profile_name.toml" mode
  mode=$(stat -c '%a' "$destination" 2>/dev/null || stat -f '%Lp' "$destination" 2>/dev/null || printf '600')
  if ! {
    printf 'name = "%s"\n' "$profile_name"
    printf 'description = "%s"\n' "$description"
    printf 'developer_instructions = "%s"\n' "$instructions"
    printf 'model = "%s"\n' "$model"
    [[ -z $sandbox_mode ]] || printf 'sandbox_mode = "%s"\n' "$sandbox_mode"
  } > "$temporary"; then
    rm -f -- "$temporary"
    return 1
  fi
  if ! chmod "$mode" "$temporary"; then
    rm -f -- "$temporary"
    return 1
  fi
  staged_profiles+=("$temporary")
}

prepare_profile_install() {
  local index destination backup
  for ((index=0; index<${#profile_destinations[@]}; index++)); do
    destination=${profile_destinations[$index]}
    backup="$profile_stage_dir/backup.$index"
    profile_backups+=("$backup")
    if [[ -f $destination ]]; then
      cp -p -- "$destination" "$backup"
      profile_had_destination+=(1)
    else
      profile_had_destination+=(0)
    fi
  done
}

validate_profile_destinations() {
  local destination
  for destination in "$@"; do
    [[ ! -L $destination && (! -e $destination || -f $destination) ]] || {
      printf 'profile destination is not a regular file: %s\n' "$destination" >&2
      return 1
    }
  done
}

# Percent-encode unsafe bytes so success records remain one-line key/value data.
encode_record_value() {
  local LC_ALL=C value=$1 output character hex index
  output=
  for ((index=0; index<${#value}; index++)); do
    character=${value:index:1}
    case $character in [A-Za-z0-9._~/-]) output+=$character ;; *) printf -v hex '%02X' "'$character"; output+="%$hex" ;; esac
  done
  printf '%s' "$output"
}

install_profiles() {
  local index
  profile_installing=1
  for ((index=0; index<${#profile_destinations[@]}; index++)); do
    mv -f -- "${staged_profiles[$index]}" "${profile_destinations[$index]}"
  done
  profile_installing=0
  finish_profile_transaction
}

write_profile() {
  local profile_name=$1 agents_dir=$5 destination="$5/$1.toml"
  validate_profile_destinations "$destination"
  begin_profile_transaction "$agents_dir"
  stage_profile "$@"
  profile_destinations=("$destination")
  prepare_profile_install
  install_profiles
  written_profile=$destination
}

prepare_executor() {
  local model='gpt-5.6-terra' profile_name='org-plan-executor' agents_dir="${HOME:?HOME is required}/.codex/agents"
  while (( $# )); do
    case $1 in
      --model) (( $# >= 2 )) || usage; model=$2; shift 2 ;;
      --agents-dir) (( $# >= 2 )) || usage; agents_dir=$2; shift 2 ;;
      --profile-name) (( $# >= 2 )) || usage; profile_name=$2; shift 2 ;;
      *) usage ;;
    esac
  done
  valid_model "$model" || { printf 'invalid model: %s\n' "$model" >&2; return 2; }
  valid_profile_name "$profile_name" || { printf 'invalid profile name: %s\n' "$profile_name" >&2; return 2; }
  write_profile "$profile_name" 'Executes an org-plan implementation.' \
    'Follow the assigned Org plan strictly. Use the bundled org-plan helper for state changes and run required tests. Return only concise structured evidence to the planner, never raw logs or complete transcripts.' \
    "$model" "$agents_dir"
  printf 'executor=%s model=%s profile=%s\n' "$profile_name" "$model" "$(encode_record_value "$written_profile")"
}

prepare_supervision() {
  local supervisor_model='gpt-5.6-luna' executor_model='gpt-5.6-terra' reviewer_model='gpt-5.6-sol'
  local supervisor_name='org-plan-supervisor' executor_name='org-plan-executor' reviewer_name='org-plan-reviewer'
  local agents_dir="${HOME:?HOME is required}/.codex/agents"
  while (( $# )); do
    case $1 in
      --supervisor-model) (( $# >= 2 )) || usage; supervisor_model=$2; shift 2 ;;
      --executor-model) (( $# >= 2 )) || usage; executor_model=$2; shift 2 ;;
      --reviewer-model) (( $# >= 2 )) || usage; reviewer_model=$2; shift 2 ;;
      --agents-dir) (( $# >= 2 )) || usage; agents_dir=$2; shift 2 ;;
      --supervisor-profile-name) (( $# >= 2 )) || usage; supervisor_name=$2; shift 2 ;;
      --executor-profile-name) (( $# >= 2 )) || usage; executor_name=$2; shift 2 ;;
      --reviewer-profile-name) (( $# >= 2 )) || usage; reviewer_name=$2; shift 2 ;;
      *) usage ;;
    esac
  done
  local value
  for value in "$supervisor_model" "$executor_model" "$reviewer_model"; do
    valid_model "$value" || { printf 'invalid model: %s\n' "$value" >&2; return 2; }
  done
  for value in "$supervisor_name" "$executor_name" "$reviewer_name"; do
    valid_profile_name "$value" || { printf 'invalid profile name: %s\n' "$value" >&2; return 2; }
  done
  [[ $supervisor_name != "$executor_name" && $supervisor_name != "$reviewer_name" && $executor_name != "$reviewer_name" ]] || {
    printf 'profile names must be distinct\n' >&2; return 2;
  }

  local -a destinations=(
    "$agents_dir/$supervisor_name.toml"
    "$agents_dir/$executor_name.toml"
    "$agents_dir/$reviewer_name.toml"
  )
  validate_profile_destinations "${destinations[@]}"
  begin_profile_transaction "$agents_dir"
  profile_destinations=("${destinations[@]}")
  stage_profile "$supervisor_name" 'Supervises an org-plan implementation.' \
    'Supervise with mechanical evidence gates. Delegate all implementation and corrective edits to Terra and keep one writer active. After implementation gates, select only DONE + UNREVIEWED L1s for read-only Sol verdicts; mark only accepted L1s REVIEWED, leave rejected L1s UNREVIEWED for correction and re-review, and reset materially changed accepted L1s to UNREVIEWED before correction. When none are pending, skip Sol and report review already current. Final acceptance requires a current full-suite pass and clean intended scope, never whole-branch Sol re-review. Run potentially large repository inspections, test commands, and log processing through an available context-preserving execution path that derives milestone evidence without injecting raw output into conversational context. If none is available, capture output outside conversational context and report only the command, exit status, pass/fail counts, affected scope, and the smallest diagnostic excerpt needed for a failure. Keep short fixed-output observations direct. Apply the same rule to director-side verification, and never put raw command output in supervisor or director reports. Context-mode is acceptable only when already available; do not install, require, or silently enable any context-management plugin. Filter child output into upstream decisions, actionable findings, commit IDs or ranges, test commands with pass/fail summaries, dirty-scope results, and blockers; include only the smallest relevant diagnostic excerpt when needed to understand a failure, never raw logs or complete transcripts.' \
    "$supervisor_model" "$agents_dir"
  stage_profile "$executor_name" 'Executes an org-plan implementation.' \
    'Implement only the assigned Org plan item. Use the bundled helper for state changes, preserve assigned scope, run required tests, and create exactly one conventional commit when files change. Return only concise structured evidence to Luna, never raw logs or complete transcripts.' \
    "$executor_model" "$agents_dir"
  stage_profile "$reviewer_name" 'Reviews an org-plan milestone.' \
    'Review only an assigned DONE + UNREVIEWED L1, its commit range, Goal, Tests, Done-when criteria, shared-code regression impact, and named evidence. Targeted shared context may be inspected without reopening accepted criteria. If an assigned L1 is REVIEWED, skip it and report the skip without re-auditing it. Do not edit files, modify the plan, commit, or perform routine supervision. Return only concise structured findings with evidence and an explicit ACCEPT or REJECT verdict, never raw logs or complete transcripts.' \
    "$reviewer_model" "$agents_dir" 'read-only'
  prepare_profile_install
  install_profiles
  local supervisor_path executor_path reviewer_path
  supervisor_path=$(encode_record_value "${destinations[0]}")
  executor_path=$(encode_record_value "${destinations[1]}")
  reviewer_path=$(encode_record_value "${destinations[2]}")
  printf 'supervisor=%s supervisor_model=%s supervisor_profile=%s executor=%s executor_model=%s executor_profile=%s reviewer=%s reviewer_model=%s reviewer_profile=%s\n' \
    "$supervisor_name" "$supervisor_model" "$supervisor_path" \
    "$executor_name" "$executor_model" "$executor_path" \
    "$reviewer_name" "$reviewer_model" "$reviewer_path"
}

cmd=${1:-}; shift || true
case $cmd in
  prepare-executor) prepare_executor "$@" ;;
  prepare-supervision) prepare_supervision "$@" ;;
  validate) [ $# = 1 ] || usage; parse "$1" ;;
  next)
    [ $# = 2 ] || usage; parse "$1"; case $2 in
      l1) i=$(active_l1) || exit 1; print_item "$i" ;;
      l2) p=$(active_l1) || exit 1; for ((i=0;i<count;i++)); do (( levels[$i] == 2 && parents[$i] == p )) && [[ ${states[$i]} == WIP ]] && { print_item "$i"; exit; }; done; for ((i=0;i<count;i++)); do (( levels[$i] == 2 && parents[$i] == p )) && [[ ${states[$i]} == TODO ]] && { print_item "$i"; exit; }; done; exit 1 ;;
      review) for ((i=0;i<count;i++)); do (( levels[$i] == 1 )) && [[ ${states[$i]} == DONE && ${review_status[$i]} == UNREVIEWED ]] && { print_item "$i"; exit; }; done; exit 1 ;;
      *) usage;; esac ;;
  summary)
    [ $# = 1 ] || usage; parse "$1"
    for s in TODO WIP DONE; do n=0; for ((i=0;i<count;i++)); do (( levels[i] == 1 )) && [[ ${states[i]} == "$s" ]] && n=$((n+1)); done; printf 'L1 %s=%s\n' "$s" "$n"; done
    for s in TODO WIP DONE; do n=0; for ((i=0;i<count;i++)); do (( levels[i] == 2 )) && [[ ${states[i]} == "$s" ]] && n=$((n+1)); done; printf 'L2 %s=%s\n' "$s" "$n"; done
    i=$(active_l1) && { printf 'current '; print_item "$i"; }
    for s in REVIEWED UNREVIEWED; do n=0; for ((i=0;i<count;i++)); do (( levels[i] == 1 )) && [[ ${review_status[i]} == "$s" ]] && n=$((n+1)); done; printf 'L1 %s=%s\n' "$s" "$n"; done ;;
  describe)
    [ $# = 2 ] || usage; parse "$1"; target=$(find_id "$2") || die "unknown ID $2"
    if (( levels[$target] == 1 )); then label=Goal; else label=Why; fi
    printf 'L%s %s\n%s: %s\n' "${levels[$target]}" "${titles[$target]}" "$label" "${field_value[$target:$label]}" ;;
  review)
    [ $# = 3 ] || usage; original=$1; parse "$original"; target=$(find_id "$2") || die "unknown ID $2"; new=$3
    (( levels[$target] == 1 )) || die "ID $2 is not an L1"
    [[ $new =~ ^(UNREVIEWED|REVIEWED)$ ]] || usage
    [[ $new != REVIEWED || ${states[$target]} == DONE ]] || die "cannot review unfinished L1 $2"
    tmp=$(mktemp "${original}.tmp.XXXXXX"); trap 'rm -f "$tmp"' EXIT HUP INT TERM
    awk -v line="${review_lines[$target]}" -v status="$new" 'NR==line { sub(/UNREVIEWED|REVIEWED/, status) } {print}' "$original" > "$tmp"
    write_plan_candidate "$original" "$tmp" ;;
  l2)
    [ $# = 2 ] || usage; parse "$1"; grep -E -- "$2" /dev/null >/dev/null 2>&1 || { [ $? = 1 ] || die 'invalid regular expression'; }
    matched=0; for ((i=0;i<count;i++)); do (( levels[i] == 2 )) || continue; block=$(sed -n "${starts[$i]},${ends[$i]}p" "$plan"); if printf '%s\n' "$block" | grep -E -q -- "$2"; then printf '%s\n' "$block"; matched=1; fi; done; (( matched )) || die 'no matching L2 blocks' ;;
  set)
    if [ $# -lt 3 ] || [ $# -gt 4 ]; then usage; fi; original=$1; parse "$original"; target=$(find_id "$2") || die "unknown ID $2"; new=$3; force=${4:-}; [[ $new =~ ^(TODO|WIP|DONE)$ ]] || usage
    old=${states[$target]}; [[ -z $force || $force == --force ]] || usage
    if [[ -z $force ]]; then [[ ($old == TODO && $new == WIP) || ($old == WIP && $new == DONE) ]] || die "invalid transition $old -> $new"; fi
    if [[ -n $force ]]; then printf 'force: overriding %s -> %s\n' "$old" "$new" >&2; fi
    reset_review=0; (( levels[$target] != 1 )) || [[ $new != WIP || ${review_status[$target]} != REVIEWED ]] || reset_review=1
    tmp=$(mktemp "${original}.tmp.XXXXXX"); trap 'rm -f "$tmp"' EXIT HUP INT TERM
    awk -v line="${lines[$target]}" -v state="$new" -v reset_line="${review_lines[$target]:-0}" -v reset_review="$reset_review" '
      NR==line { sub(/TODO|WIP|DONE/, state) }
      reset_review && NR==reset_line { sub(/REVIEWED/, "UNREVIEWED") }
      {print}
    ' "$original" > "$tmp"
    write_plan_candidate "$original" "$tmp" ;;
  --help|-h|'') usage ;;
  *) usage ;;
esac
